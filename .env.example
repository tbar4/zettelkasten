# Copy this file to .env and edit. All values have working defaults — you can
# `docker compose up` with an empty .env. Fill these in to enable optional
# integrations.

# --- Optional integrations ---
# Without READWISE_TOKEN, the readwise service starts and idles (no sync).
# Get a token from https://readwise.io/access_token
READWISE_TOKEN=

# NOTION_TOKEN is not needed here — the Notion importer takes the token via
# the web UI on a per-import basis.

# --- Mirror service ---
# Host directory that gets the markdown mirror + git auto-commits.
# Must be an absolute path (docker compose does not expand ~).
ZK_MIRROR_HOST_DIR=${HOME}/Notes/zettel

# Git identity used by the mirror's auto-commits. Falls back to "zk mirror
# <mirror@zk.local>" if blank (set on first commit by the mirror itself).
MIRROR_GIT_USER_NAME=
MIRROR_GIT_USER_EMAIL=

# --- ML service (runs natively on host, not in Docker) ---
# embedding-worker reaches the ML service via the Docker host gateway.
# Override only if the ML service runs on a non-default port.
ML_BASE_URL=http://host.docker.internal:8000
